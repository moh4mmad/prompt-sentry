# Runtime mode: monitor, protect, or red_team
APP_ENVIRONMENT=development
DOCS_ENABLED=true
ENABLE_HSTS=false
PROMPT_SENTRY_MODE=protect

# Default score thresholds
RISK_MONITOR_THRESHOLD=0.25
RISK_SANITIZE_THRESHOLD=0.50
RISK_BLOCK_THRESHOLD=0.75
RISK_ALERT_THRESHOLD=0.90

# Audit logging: file | stdout | postgres
AUDIT_LOG_SINK=file
AUDIT_LOG_PATH=logs/audit.jsonl
# DATABASE_URL=postgresql://prompt_sentry:password@localhost:5432/prompt_sentry
# Avoid retaining prompt content in production. A SHA-256 input hash is always retained.
AUDIT_INCLUDE_REDACTED_INPUT=true

# API hardening — set API_KEY to require X-API-Key header on all requests
# API_KEY=your-secret-key-here
# Separate credential used only by the dashboard's server-side proxy.
# DASHBOARD_API_KEY=another-long-random-secret
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_FAIL_OPEN=false
MAX_REQUEST_BYTES=1048576
# Only trust X-Forwarded-For from these networks (comma-separated CIDRs).
TRUSTED_PROXY_CIDRS=
# Comma-separated browser origins. Leave empty when using the same-origin dashboard proxy.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# LLM classifier (opt-in ensemble scorer)
# Blends an LLM confidence score with rule scores for better recall on novel attacks.
LLM_CLASSIFIER_ENABLED=false

# Provider: anthropic | openai | bedrock
LLM_CLASSIFIER_PROVIDER=anthropic

# Blend weights (must sum to 1.0)
LLM_CLASSIFIER_WEIGHT=0.6
RULE_CLASSIFIER_WEIGHT=0.4

# ── Anthropic ──────────────────────────────────────────────────────────────
# pip install ".[llm]"
# Falls back to ANTHROPIC_API_KEY env var if not set.
LLM_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# LLM_CLASSIFIER_API_KEY=sk-ant-...

# ── OpenAI (also works for Azure OpenAI, Ollama, any OpenAI-compatible API) ─
# pip install ".[llm-openai]"
# LLM_CLASSIFIER_PROVIDER=openai
# LLM_CLASSIFIER_MODEL=gpt-4o-mini
# LLM_CLASSIFIER_API_KEY=sk-...
# LLM_CLASSIFIER_OPENAI_BASE_URL=https://api.openai.com/v1   # override for Azure/Ollama

# ── AWS Bedrock ────────────────────────────────────────────────────────────
# pip install ".[llm-bedrock]"
# Uses IAM credentials from env (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) or instance role.
# LLM_CLASSIFIER_PROVIDER=bedrock
# LLM_CLASSIFIER_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
# LLM_CLASSIFIER_AWS_REGION=us-east-1
