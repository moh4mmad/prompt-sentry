# Generate unique values with: openssl rand -base64 32
POSTGRES_PASSWORD=replace-with-a-long-random-password
API_KEY=replace-with-a-long-random-api-key
DASHBOARD_API_KEY=replace-with-a-different-random-key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-with-a-long-random-password

# Set this to the load balancer/reverse proxy network when X-Forwarded-For is used.
TRUSTED_PROXY_CIDRS=
# The dashboard uses a same-origin server proxy, so CORS can normally remain disabled.
CORS_ALLOWED_ORIGINS=
